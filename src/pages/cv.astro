---
import Base from "../layouts/Base.astro";
---

<Base title="CV - Brendan Bennett">
  <h1>CV</h1>
  <p class="intro">Education, experience, and projects.</p>

  <section class="cv-section">
    <h2>Experience</h2>
    <article class="cv-entry">
      <div class="cv-header">
        <h3>PhD Candidate</h3>
        <span class="cv-date">Sept 2025 - present</span>
      </div>
      <div class="cv-org">University of Manchester, UK</div>
    </article>

    <article class="cv-entry">
      <div class="cv-header">
        <h3>Graduate Software Engineer</h3>
        <span class="cv-date">Oct 2024 - Sept 2025</span>
      </div>
      <div class="cv-org">Sage UK, Newcastle-upon-Tyne</div>
      <ul>
        <li>
          Developed strategically vital features to penetrate the UK
          construction accounting market requiring complex validation and logic
          in PHP and database migrations.
          <li>
            Learnt how to navigate vast codebases independently while knowing
            when to seek help from seniors.
          </li>
          <li>
            Worked closely and collaboratively with my PM to navigate the
            intricate deliverable requirements.
          </li>
        </li>
      </ul>
    </article>

    <article class="cv-entry">
      <div class="cv-header">
        <h3>Software Engineer Internship</h3>
        <span class="cv-date">Jul - Sept 2022</span>
      </div>
      <div class="cv-org">Mystic AI, Bath</div>
      <ul>
        <li>
          Designed and implemented a simulation of the company's server cluster
          in Python and used this to develop more efficient distributed
          computing algorithms.
        </li>
        <li>
          Re-implemented ML models in the TensorRT format as proof-of-concept,
          slashing inference times by 50%.
        </li>
        <li>Streamlined API Exception handling enhancing usability.</li>
      </ul>
    </article>
  </section>

  <section class="cv-section">
    <h2>Projects</h2>

    <article class="cv-entry">
      <div class="cv-header">
        <h3>Echo State Networks for Chaotic Time Series Prediction</h3>
        <span class="cv-header-right">
          <span class="cv-tag">Master's Thesis</span>
          <a
            href="https://github.com/brendanbennett/individual-project"
            class="cv-github"
            target="_blank">GitHub ↗</a
          >
        </span>
      </div>
      <ul>
        <li>
          Rigorously evaluated ESNs' performance in predicting and forecasting
          real life and artificial chaotic signals with respect to their
          frequency signatures, using both novel techniques and those from
          literature.
        </li>
        <li>
          Developed a novel metric for evaluating ESN encoding capacity across
          the frequency domain.
        </li>
      </ul>
    </article>

    <article class="cv-entry">
      <div class="cv-header">
        <h3>Deorbiting Satellite Prediction</h3>
        <span class="cv-header-right">
          <span class="cv-tag">Master's Group Project</span>
          <a
            href="https://github.com/brendanbennett/deorbiter"
            class="cv-github"
            target="_blank">GitHub ↗</a
          >
        </span>
      </div>
      <ul>
        <li>
          Simulation of a deorbiting satellite and prediction of its landing
          site using an Extended Kalman Filter.
        </li>
        <li>
          Project manager of a team of 6, leading software design decisions and
          collaboration across diverse academic backgrounds.
        </li>
      </ul>
    </article>

    <article class="cv-entry">
      <div class="cv-header">
        <h3>AlphaZero Implementation in Rust</h3>
        <a
          href="https://github.com/brendanbennett/ultimate-xos-rust"
          class="cv-github"
          target="_blank">GitHub ↗</a
        >
      </div>
      <p>
        Rust implementation of the groundbreaking DeepMind RL algorithm.
        Demonstrated on ultimate noughts and crosses.
      </p>
    </article>

    <article class="cv-entry">
      <div class="cv-header">
        <h3>Deep Q-Learning for Poker</h3>
        <span class="cv-header-right">
          <span class="cv-tag">A-Level Project</span>
        </span>
      </div>
      <p>
        Developed a basic RL framework in Python to apply Deep Q-learning to
        Poker.
      </p>
    </article>
  </section>

  <section class="cv-section">
    <h2>Education</h2>

    <article class="cv-entry">
      <div class="cv-header">
        <h3>MSc Predictive Modelling and Scientific Computing</h3>
        <span class="cv-date">Oct 2023 - Oct 2024</span>
      </div>
      <div class="cv-org">University of Warwick</div>
      <div class="cv-detail">Distinction</div>
      <p class="cv-modules">
        Key modules: High performance computing, Scientific machine learning,
        Algorithms and optimisation, Particle based modelling, Data mining and
        applied machine learning.
      </p>
    </article>

    <article class="cv-entry">
      <div class="cv-header">
        <h3>BSc Mathematics</h3>
        <span class="cv-date">Oct 2020 - Jul 2023</span>
      </div>
      <div class="cv-org">University of Warwick</div>
      <div class="cv-detail">First Class Honours</div>
      <p class="cv-modules">
        Key Modules: Mathematics of machine learning, Multivariable calculus,
        Linear algebra, Algebraic topology, Groups and rings
      </p>
    </article>

    <article class="cv-entry">
      <div class="cv-header">
        <h3>A-levels: Maths, Further Maths, Computer Science, Music</h3>
        <span class="cv-date">Sept 2018 - Jun 2020</span>
      </div>
      <div class="cv-org">Woodbridge School</div>
      <div class="cv-detail">A*A*A*A</div>
    </article>
  </section>

  <section class="cv-section">
    <h2>Skills</h2>
    <div class="skills-grid">
      <div class="skill-group">
        <h3>Topics</h3>
        <div class="skill-tags">
          <span class="skill">Machine Learning</span>
          <span class="skill">API Design</span>
          <span class="skill">Algorithm Design</span>
          <span class="skill">High Performance Computing</span>
          <span class="skill">CI/CD</span>
          <span class="skill">Linux & Docker</span>
          <span class="skill">Project Management</span>
        </div>
      </div>
      <div class="skill-group">
        <h3>Languages</h3>
        <div class="skill-tags">
          <span class="skill experienced">Python</span>
          <span class="skill experienced">SQL</span>
          <span class="skill experienced">PHP</span>
          <span class="skill intermediate">Rust</span>
          <span class="skill intermediate">JavaScript</span>
          <span class="skill intermediate">HTML/CSS</span>
          <span class="skill basic">C</span>
          <span class="skill basic">C++</span>
        </div>
      </div>
    </div>
  </section>

  <section class="cv-section achievements">
    <h2>Achievements</h2>
    <p>
      Distinctions in Intermediate Mathematical Olympiads. Qualifier for the
      British Mathematical Olympiad.
    </p>
  </section>
</Base>

<style>
  .intro {
    font-family: var(--font-serif);
    font-style: italic;
    color: var(--text-muted);
    margin-bottom: 2rem;
  }

  .cv-section {
    margin-bottom: 2.5rem;
  }

  .cv-section h2 {
    font-size: 1.3rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--accent);
    border-bottom: 1px solid var(--border);
    padding-bottom: 0.5rem;
    margin-bottom: 1rem;
    font-family: var(--font-sans);
    font-weight: 600;
  }

  .cv-entry {
    padding: 1rem 0;
    border-bottom: 1px solid var(--border);
  }

  .cv-entry:last-child {
    border-bottom: none;
  }

  .cv-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }

  .cv-header h3 {
    font-size: 1.05rem;
    margin: 0;
    font-family: var(--font-serif);
    min-width: 0;
  }

  .cv-date {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    color: var(--text-muted);
    white-space: nowrap;
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  .cv-header-right {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-shrink: 0;
  }

  .cv-tag {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--accent);
    background: var(--surface);
    padding: 0.15rem 0.6rem;
    border-radius: 12px;
    white-space: nowrap;
    font-weight: 400;
  }

  .cv-github {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    color: var(--text-muted);
    border: 1px solid var(--border);
    padding: 0.15rem 0.6rem;
    border-radius: 12px;
    white-space: nowrap;
    font-weight: 400;
    transition: all 0.15s ease;
  }

  .cv-github:hover {
    color: var(--accent);
    border-color: var(--accent-dim);
    background: var(--surface);
  }

  .cv-org {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
    font-style: italic;
    font-family: var(--font-serif);
  }

  .cv-detail {
    font-size: 0.85rem;
    color: var(--accent);
    font-weight: 500;
    margin-bottom: 0.25rem;
  }

  .cv-modules {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 0.25rem;
  }

  ul {
    list-style: none;
    padding: 0;
  }

  li {
    position: relative;
    padding-left: 1rem;
    margin-bottom: 0.4rem;
    font-size: 0.9rem;
    color: var(--text);
  }

  li::before {
    content: ">";
    position: absolute;
    left: 0;
    color: var(--accent-dim);
  }

  .skills-grid {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .skill-group h3 {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 0.5rem;
    font-family: var(--font-sans);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .skill {
    font-family: var(--font-sans);
    font-size: 0.8rem;
    padding: 0.25rem 0.7rem;
    border-radius: 12px;
    background: var(--surface);
    color: var(--text-muted);
    border: 1px solid var(--border);
    font-weight: 400;
  }

  .skill.experienced {
    color: var(--accent);
    border-color: var(--accent-dim);
  }

  .skill.intermediate {
    color: var(--text);
    border-color: var(--border);
  }

  .achievements p {
    color: var(--text-muted);
    font-style: italic;
    font-family: var(--font-serif);
    font-size: 0.95rem;
  }

  @media (max-width: 768px) {
    .cv-header {
      flex-direction: column;
      gap: 0.25rem;
    }
  }
</style>
